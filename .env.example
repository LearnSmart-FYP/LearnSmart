# Required core services
# These are needed for the FastAPI backend and Docker Compose setup.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=learning_platform

# Neo4j
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=learning_platform
QDRANT_DIMENSIONS=1024

# Ollama (local Docker fallback)
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MAX_REQUESTS=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_GPU=0
OLLAMA_MODELS=[{"name":"qwen2.5:7b","key":"qwen-7b","context_window":32768,"max_output":8192}]
OLLAMA_DEFAULT_MODEL=qwen-7b
OLLAMA_EMBED_MODELS=[{"name":"mxbai-embed-large","key":"mxbai-embed-large","dimensions":1024,"max_tokens":512}]
OLLAMA_DEFAULT_EMBED_MODEL=mxbai-embed-large

# Backend runtime
MAX_CONTEXT_USAGE=0.8
CHUNK_OVERLAP_TOKENS=500
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=["http://localhost:5173"]

# Auth
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Required config keys for provider wiring
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_REQUESTS=10
DEEPSEEK_MODELS=[{"name":"deepseek-chat","key":"deepseek-chat","context_window":131072,"max_output":8192},{"name":"deepseek-reasoner","key":"deepseek-reasoner","context_window":131072,"max_output":65536,"timeout":600}]
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_REQUESTS=10
OPENROUTER_MODELS=[{"name":"deepseek/deepseek-r1-0528:free","key":"deepseek-r1-free","context_window":163800,"max_output":163800}]
OPENROUTER_DEFAULT_MODEL=deepseek-r1-free

# Qwen / DashScope
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MAX_REQUESTS=10
QWEN_MODELS=[{"name":"qwen-long","key":"qwen-long","context_window":10000000,"max_output":32768}]
QWEN_DEFAULT_MODEL=qwen-long

# Optional OAuth
# Leave blank if you do not need social login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback

# Email / notification delivery
# Local setup can use console mode so no SMTP credentials are required.
EMAIL_PROVIDER=console
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=LearnSmart
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
